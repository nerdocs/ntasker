msgstr "Ungültige Sprache: {value!r}. Erlaubt: {allowed}"

#: src/ntasker/settings.py:95
msgid ""
"Directory containing project symlinks (e.g. /home/<user>/Projects). Read for "
"/api/projects."
msgstr ""
"Verzeichnis mit Projekt-Symlinks (z.B. /home/<user>/Projekte). Wird für "
"/api/projects gelesen."

#: src/ntasker/settings.py:99
msgid ""
"Vendor assets (Tabler/Alpine): cdn (default, jsDelivr + SRI), local (from "
"user-data dir, populate via `ntasker assets fetch`), auto (local if cache "
"complete, else cdn)."
msgstr ""
"Vendor-Assets (Tabler/Alpine): cdn (default, jsDelivr + SRI), local (aus "
"User-Data-Dir, vorher mit `ntasker assets fetch` laden), auto (local wenn "
"Cache vollständig, sonst cdn)."

#: src/ntasker/settings.py:104
msgid "UI language: 'auto' (Accept-Language header, fallback English), 'en', or 'de'."
msgstr ""
"UI-Sprache: 'auto' (Accept-Language-Header, Fallback Englisch), 'en' oder "
"'de'."

