msgid "Slash command file name (default: task -> /task <id>)."
msgstr "Slash-Command-Dateiname (Default: task -> /task <id>)."

#: src/ntasker/cli.py:895
msgid "Overwrite divergent files (timestamped backup is created)."
msgstr "Abweichende Dateien überschreiben (Zeitstempel-Backup wird angelegt)."

#: src/ntasker/cli.py:900
msgid "Show planned actions without writing."
msgstr "Geplante Aktionen anzeigen ohne zu schreiben."

#: src/ntasker/cli.py:905
msgid "Read-only status check. Exit 0=identical, 1=drift, 2=not installed."
msgstr "Read-only-Status-Check. Exit 0=identisch, 1=Drift, 2=nicht installiert."

#: src/ntasker/cli.py:910
msgid "Override ~/.claude (also via NTASKER_CLAUDE_HOME env var)."
msgstr "~/.claude überschreiben (auch via NTASKER_CLAUDE_HOME)."

#: src/ntasker/cli.py:917
msgid "Manage vendor assets (CDN by default, opt-in local cache)."
msgstr "Vendor-Assets verwalten (CDN-Default, opt-in lokal)."

#: src/ntasker/cli.py:923
msgid "Fetch vendor assets via HTTP into the user-data cache (SRI-verified)."
msgstr "Vendor-Assets via HTTP in den User-Data-Cache laden (mit SRI-Verify)."

#: src/ntasker/cli.py:928
msgid "Re-fetch existing files even when their SRI already matches."
msgstr "Vorhandene Files neu laden, auch wenn SRI bereits passt."

#: src/ntasker/cli.py:932
msgid "Delete the user-data asset cache."
msgstr "User-Data-Asset-Cache löschen."

#: src/ntasker/cli.py:936
msgid "Skip the confirmation prompt."
msgstr "Bestätigungs-Prompt überspringen."

#: src/ntasker/cli.py:940
msgid "Show cache state + active mode."
msgstr "Cache-Zustand + Modus anzeigen."

#: src/ntasker/cli.py:988
