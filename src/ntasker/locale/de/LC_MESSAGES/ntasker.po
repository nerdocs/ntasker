#: src/ntasker/cli.py:1009
msgid "Run the FastAPI server"
msgstr "FastAPI-Server starten"

#: src/ntasker/cli.py:1017
msgid ""
"Start the server as a detached background process. Idempotent: returns 0 "
"if a server is already answering /healthz."
msgstr ""
"Server als detached Hintergrundprozess starten. Idempotent: liefert 0, "
"wenn bereits ein Server auf /healthz antwortet."

#: src/ntasker/cli.py:1026
