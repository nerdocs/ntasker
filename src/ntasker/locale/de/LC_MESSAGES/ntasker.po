msgstr "claude_permission_mode muss einer von {modes} sein (war {value!r})."

#: src/ntasker/settings.py:231
msgid ""
"Vendor assets (Tabler/Alpine): cdn (default, jsDelivr + SRI), local (from"
" user-data dir, populate via `ntasker assets fetch`), auto (local if "
"cache complete, else cdn)."
msgstr ""
"Vendor-Assets (Tabler/Alpine): cdn (default, jsDelivr + SRI), local (aus "
"User-Data-Dir, vorher mit `ntasker assets fetch` laden), auto (local wenn"
" Cache vollständig, sonst cdn)."

#: src/ntasker/settings.py:236
msgid ""
"UI language: 'auto' (Accept-Language header, fallback English), 'en', or "
"'de'."
msgstr ""
"UI-Sprache: 'auto' (Accept-Language-Header, Fallback Englisch), 'en' oder"
" 'de'."

#: src/ntasker/settings.py:239
msgid ""
"Default view on startup: 'list' (classic task list) or 'kanban' (4-column"
" board). The frontend remembers the last user choice in localStorage; "
"this setting drives the initial pick on a fresh browser."
msgstr ""
"Standard-Ansicht beim Start: 'list' (klassische Aufgabenliste) oder "
"'kanban' (4-Spalten-Board). Das Frontend merkt sich die letzte Auswahl im"
" localStorage; diese Einstellung greift nur beim ersten Aufruf in einem "
"frischen Browser."

#: src/ntasker/settings.py:244
msgid ""
"Base path for project names, e.g. '~/Projekte'. Discovered Claude "
"projects below it are named relative to it (the folder right under the "
"base becomes the project name) instead of relative to your home "
"directory. Unset to fall back to home-relative names. ENV: "
"NTASKER_PROJECTS_BASE."
msgstr ""
"Basispfad für Projektnamen, z. B. '~/Projekte'. Darunter gefundene "
"Claude-Projekte werden relativ dazu benannt (der Ordner direkt unterhalb "
"der Basis wird zum Projektnamen) statt relativ zu deinem Home-"
"Verzeichnis. Leer lassen, um auf Home-relative Namen zurückzufallen. ENV:"
" NTASKER_PROJECTS_BASE."

#: src/ntasker/settings.py:251
msgid ""
"Permission mode for interactive Claude sessions: 'default' (normal -- "
"Claude asks first), 'auto' (auto-accept actions), 'plan' (plan only, no "
"changes), or 'bypassPermissions' (skip every prompt -- dangerous). Passed"
" to the CLI as --permission-mode. Default: default."
msgstr ""
"Berechtigungsmodus für interaktive Claude-Sitzungen: 'default' (normal --"
" Claude fragt zuerst), 'auto' (Aktionen automatisch bestätigen), 'plan' "
"(nur planen, keine Änderungen) oder 'bypassPermissions' (jede Abfrage "
"überspringen -- gefährlich). Wird als --permission-mode an die CLI "
"übergeben. Standard: default."

#: src/ntasker/templates/index.html:72
msgid "Show empty projects"
msgstr "Leere Projekte anzeigen"

#: src/ntasker/templates/index.html:480
msgid "Create + Run"
msgstr "Anlegen + Starten"

#: src/ntasker/templates/settings.html:128
msgid "Permission mode"
msgstr "Berechtigungsmodus"

#: src/ntasker/templates/settings.html:130
msgid ""
"How a spawned Claude session handles permissions. Passed to the CLI as "
"--permission-mode."
msgstr ""
"Wie eine gestartete Claude-Sitzung mit Berechtigungen umgeht. Wird als "
"--permission-mode an die CLI übergeben."

#: src/ntasker/templates/settings.html:139
msgid "Claude asks before it edits a file or runs a command."
msgstr "Claude fragt, bevor es eine Datei ändert oder einen Befehl ausführt."

#: src/ntasker/templates/settings.html:147
msgid "Auto"
msgstr "Auto"

#: src/ntasker/templates/settings.html:148
msgid "Claude accepts its own actions automatically."
msgstr "Claude bestätigt seine eigenen Aktionen automatisch."

#: src/ntasker/templates/settings.html:156
msgid "Plan"
msgstr "Plan"

#: src/ntasker/templates/settings.html:157
msgid "Claude only plans and makes no changes."
msgstr "Claude plant nur und nimmt keine Änderungen vor."

#: src/ntasker/templates/settings.html:165
msgid "Bypass permissions"
msgstr "Berechtigungen umgehen"

#: src/ntasker/templates/settings.html:166
msgid "Claude skips every confirmation and runs unattended."
msgstr "Claude überspringt jede Bestätigung und läuft unbeaufsichtigt."

#: src/ntasker/templates/settings.html:175
msgid "This can be dangerous."
msgstr "Das kann gefährlich sein."

#: src/ntasker/templates/settings.html:176
msgid ""
"With permissions bypassed, Claude can change or delete files and run "
"shell commands in the project directory without asking first. Only use it"
" for projects you fully trust."
msgstr ""
"Wenn Berechtigungen umgangen werden, kann Claude im Projektverzeichnis "
"Dateien ändern oder löschen und Shell-Befehle ausführen, ohne vorher zu "
"fragen. Nutze das nur für Projekte, denen du voll vertraust."

